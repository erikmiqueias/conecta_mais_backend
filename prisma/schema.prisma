// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                 String              @id @default(uuid())
  username           String
  email              String              @unique
  password           String
  avatarUrl          String?
  role               Role                @default(USER)
  emailVerified      Boolean             @default(false)
  verificationToken  String?             @unique
  verificationTokenExpiry DateTime?
  createdAt          DateTime            @default(now()) @db.Timestamptz()
  updatedAt          DateTime            @updatedAt @db.Timestamptz()
  deletedAt          DateTime?           @db.Timestamptz()
  events             Event[]
  eventSubscriptions EventSubscription[]
  eventReviews       EventReview[]

  tokens Token[]

  tickets Ticket[]
}

model Event {
  id            String      @id @default(uuid())
  name          String
  description   String      @db.Text
  eventType     EventType
  eventAddress  String
  latitude      Decimal     @db.Decimal(10, 7)
  longitude     Decimal     @db.Decimal(10, 7)
  accessCode    String?     @unique
  bannerUrl     String?
  status        EventStatus @default(SCHEDULED)
  startDateTime DateTime    @db.Timestamptz()
  endDateTime   DateTime    @db.Timestamptz()
  createdAt     DateTime    @default(now()) @db.Timestamptz()
  updatedAt     DateTime    @updatedAt @db.Timestamptz()
  deletedAt     DateTime?   @db.Timestamptz()

  organizerId String
  organizer   User   @relation(fields: [organizerId], references: [id], onDelete: Restrict)

  eventSubscriptions EventSubscription[]
  eventReviews       EventReview[]

  ticketBatches TicketBatch[]
}

model EventSubscription {
  id                   String   @id @default(uuid())
  subscriptionDateTime DateTime @default(now()) @db.Timestamptz()
  userId               String
  eventId              String
  user                 User     @relation(fields: [userId], references: [id])
  event                Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([userId, eventId])
}

model EventReview {
  id        String   @id @default(uuid())
  rating    Int
  comment   String   @db.Text
  createdAt DateTime @default(now()) @db.Timestamptz()
  updatedAt DateTime @updatedAt @db.Timestamptz()
  userId    String
  eventId   String
  user      User     @relation(fields: [userId], references: [id])
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([userId, eventId])
}

model Token {
  id     String @id @default(uuid())
  code   String @unique @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id])

  expiresAt DateTime
  createdAt DateTime @default(now())
}

model TicketBatch {
  id            String  @id @default(uuid())
  eventId       String
  batchName     String
  price         Decimal
  totalCapacity Int
  soldCount     Int     @default(0)

  event   Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  tickets Ticket[]
}

model Ticket {
  id            String       @id @default(uuid())
  userId        String
  ticketBatchId String
  status        TicketStatus @default(PENDING)

  ticketBatch TicketBatch @relation(fields: [ticketBatchId], references: [id])
  user        User        @relation(fields: [userId], references: [id])
}

enum TicketStatus {
  PENDING
  SOLD
  CHECKED_IN
}

enum Role {
  USER
  ORGANIZER
}

enum EventType {
  PRIVATE
  PUBLIC
}

enum EventStatus {
  SCHEDULED
  CANCELED
}
