{
  "compilerOptions": {
    "resolveJsonModule": true,
    "target": "es2024",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "strict": true,
    "outDir": "dist",
    "rootDir": "src",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "moduleDetection": "force",
    "paths": {
      "@modules/*": ["./src/modules/*"],
      "@schemas/*": ["./src/infra/schemas/*"],
      "@infra/*": ["./src/infra/*"],
      "@shared/*": ["./src/shared/*"],
      "@generated/*": ["./src/generated/*"]
    }
  },
  "include": ["src"]
}
